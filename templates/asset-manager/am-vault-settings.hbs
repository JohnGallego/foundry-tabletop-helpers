<form>
  <h3><i class="fa-solid fa-vault"></i> Asset Vault Settings</h3>

  <div class="form-group">
    <label>Optimize on Upload</label>
    <input type="checkbox" name="optimizeOnUpload" {{#if optimizeOnUpload}}checked{{/if}} />
    <p class="notes">Automatically optimize images when uploading through the Asset Vault.</p>
  </div>

  <hr />
  <h3><i class="fa-solid fa-sliders"></i> Optimization Presets</h3>
  <p class="notes">Configure the default optimization settings for each preset profile. Quality is 1-100%.</p>

  {{#each presets}}
  <fieldset style="margin-bottom: 8px; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; padding: 8px 12px;">
    <legend style="font-weight: 600; text-transform: capitalize;">{{key}}</legend>
    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;">
      <div class="form-group" style="margin: 0;">
        <label style="font-size: 0.85em;">Max Width (px)</label>
        <input type="number" name="{{key}}_maxWidth" value="{{maxWidth}}" min="16" max="16384" step="1" />
      </div>
      <div class="form-group" style="margin: 0;">
        <label style="font-size: 0.85em;">Max Height (px)</label>
        <input type="number" name="{{key}}_maxHeight" value="{{maxHeight}}" min="16" max="16384" step="1" />
      </div>
      <div class="form-group" style="margin: 0;">
        <label style="font-size: 0.85em;">Quality (%)</label>
        <input type="number" name="{{key}}_quality" value="{{quality}}" min="1" max="100" step="1" />
      </div>
    </div>
  </fieldset>
  {{/each}}

  <hr />
  <h3><i class="fa-solid fa-server"></i> Optimizer Server</h3>
  <p class="notes">Optional server companion for faster, higher-quality optimization via Sharp/FFmpeg.</p>

  <div class="form-group">
    <label>Server URL</label>
    <input type="text" name="optimizerUrl" value="{{optimizerUrl}}" placeholder="https://your-server/optimizer" />
    <p class="notes">Leave empty to use browser-based optimization only.</p>
  </div>

  <div class="form-group">
    <label>Auth Token</label>
    <input type="password" name="optimizerToken" value="{{optimizerToken}}" placeholder="Server auth token" />
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit" class="dialog-button default">
      <i class="fa-solid fa-save"></i> Save
    </button>
  </footer>
</form>
