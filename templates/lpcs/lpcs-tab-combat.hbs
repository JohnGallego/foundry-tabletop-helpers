{{!-- lpcs-tab-combat.hbs --}}
{{!-- Combat tab: weapons table, actions/bonus actions/reactions drawers --}}
<section class="lpcs-tab lpcs-tab--combat {{#if isActiveTab}}active{{/if}}"
         id="lpcs-tab-panel-combat"
         role="tabpanel"
         aria-labelledby="lpcs-tab-btn-combat"
         data-tab="combat"
         data-group="primary"
         {{#unless isActiveTab}}hidden{{/unless}}>

  {{!-- Weapons --}}
  {{#if vm.weapons.length}}
  <div class="lpcs-weapons-section">
    <h3 class="lpcs-section-title">Weapons</h3>
    <table class="lpcs-weapons-table" aria-label="Equipped weapons">
      <thead>
        <tr>
          <th scope="col" class="lpcs-col-name">Weapon</th>
          <th scope="col" class="lpcs-col-atk">ATK</th>
          <th scope="col" class="lpcs-col-dmg">Damage</th>
          <th scope="col" class="lpcs-col-range">Range</th>
        </tr>
      </thead>
      <tbody>
        {{#each vm.weapons}}
        <tr class="lpcs-weapon-row" data-item-id="{{id}}">
          <td class="lpcs-col-name">
            <button class="lpcs-weapon-use rollable" data-action="useItem" data-item-id="{{id}}"
                    type="button" aria-label="Use {{name}}">
              {{#if img}}<img src="{{img}}" alt="" class="lpcs-item-icon" aria-hidden="true">{{/if}}
              <span class="lpcs-weapon-name">{{name}}</span>
              {{#if mastery}}<span class="lpcs-mastery-badge">{{mastery}}</span>{{/if}}
            </button>
          </td>
          <td class="lpcs-col-atk lpcs-atk-bonus">{{attackBonus}}</td>
          <td class="lpcs-col-dmg lpcs-damage">{{damage}}</td>
          <td class="lpcs-col-range">{{range}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  {{!-- Actions --}}
  <div class="lpcs-actions-section">
    <h3 class="lpcs-section-title">Actions</h3>
    {{#if vm.actions.length}}
    <div class="lpcs-action-list">
      {{#each vm.actions}}
      {{> lpcs-drawer drawerId=(concat "action-" id) title=name img=img uses=uses
                      recharge=recharge description=description}}
      {{/each}}
    </div>
    {{else}}
    <p class="lpcs-empty-state">No actions.</p>
    {{/if}}
  </div>

  {{!-- Bonus Actions --}}
  <div class="lpcs-bonus-section">
    <h3 class="lpcs-section-title">Bonus Actions</h3>
    {{#if vm.bonusActions.length}}
    <div class="lpcs-action-list">
      {{#each vm.bonusActions}}
      {{> lpcs-drawer drawerId=(concat "bonus-" id) title=name img=img uses=uses
                      recharge=recharge description=description}}
      {{/each}}
    </div>
    {{else}}
    <p class="lpcs-empty-state">No bonus actions.</p>
    {{/if}}
  </div>

  {{!-- Reactions --}}
  <div class="lpcs-reactions-section">
    <h3 class="lpcs-section-title">Reactions</h3>
    {{#if vm.reactions.length}}
    <div class="lpcs-action-list">
      {{#each vm.reactions}}
      {{> lpcs-drawer drawerId=(concat "reaction-" id) title=name img=img uses=uses
                      recharge=recharge description=description}}
      {{/each}}
    </div>
    {{else}}
    <p class="lpcs-empty-state">No reactions.</p>
    {{/if}}
  </div>

</section>

