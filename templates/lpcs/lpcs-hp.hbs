{{!-- lpcs-hp.hbs --}}
{{!-- HP + Death Saves vitals area. --}}
{{!-- Context: hp (LPCSHitPoints), deathSaves (LPCSDeathSaves) --}}
{{!-- Both views are always in the DOM; _onRender() manages active/hidden classes. --}}

{{!-- Outer positioning context — drawer is a sibling to the vitals container so the
     drop-shadow filter on .lpcs-hp-widget-wrap does not clip or affect the drawer. --}}
<div class="lpcs-hp-outer">

  {{!-- Vitals container: relative, holds both overlapping views --}}
  <div class="lpcs-vitals-container">

    {{!-- HP View — shown when HP > 0 --}}
    <div class="lpcs-vitals-state hp-view {{#if deathSaves.show}}hidden{{else}}active{{/if}}"
         data-vitals="hp">

      <div class="lpcs-hp-widget-wrap">

        {{!-- Labels above the bar --}}
        <div class="lpcs-hp-labels">
          <div class="lpcs-hp-label-main">
            <i class="fas fa-heart lpcs-hp-heart" aria-hidden="true"></i>
            <span class="lpcs-hp-label-text">HP</span>
          </div>
          <span class="lpcs-hp-label-temp">Temp</span>
        </div>

        {{!-- The bar IS the tap target: tapping opens the HP management drawer --}}
        <div class="lpcs-hp-bar-widget"
             data-action="openHPDrawer"
             role="button"
             tabindex="0"
             aria-label="HP: {{hp.value}} of {{hp.max}}{{#if hp.temp}}, {{hp.temp}} temporary{{/if}} — tap to manage HP">

          {{!-- Red crimson fill: width = current HP % --}}
          <div class="lpcs-hp-fill" style="width: {{hp.pct}}%;" aria-hidden="true"></div>

          {{!-- Current / max HP values centered in the main HP zone --}}
          <div class="lpcs-hp-bar-values" aria-hidden="true">
            <span class="lpcs-hp-value">{{hp.value}}</span>
            <span class="lpcs-hp-sep">/</span>
            <span class="lpcs-hp-max-val">{{hp.max}}</span>
          </div>

          {{!-- Temp HP zone: rightmost 20% of the bar — blue fill when temp HP is active --}}
          <div class="lpcs-hp-temp-zone {{#if hp.temp}}has-temp{{/if}}" aria-hidden="true">
            <span class="lpcs-hp-tmp-val">{{#if hp.temp}}{{hp.temp}}{{else}}—{{/if}}</span>
          </div>

        </div>

      </div>
    </div>{{!-- end .hp-view --}}

    {{!-- Death Saves View — shown when HP = 0 --}}
    <div class="lpcs-vitals-state ds-view {{#if deathSaves.show}}active{{else}}hidden{{/if}}"
         data-vitals="ds">

      {{!-- data-roll-mode drives all CSS differences between physical and digital.
           Both the group tap targets and the roll button are always in the DOM;
           CSS hides the inappropriate element for the current mode. --}}
      <div class="lpcs-ds-widget" role="group" aria-label="Death saving throws"
           data-roll-mode="{{deathSaves.rollMode}}">
        <div class="lpcs-ds-label">Death Saves</div>
        <div class="lpcs-ds-groups">

          {{!-- Success group — tap target in physical mode, display-only in digital --}}
          <div class="lpcs-ds-group lpcs-ds-group--success"
               data-action="incrementDeathSave" data-save-type="success"
               role="button" tabindex="0"
               aria-label="Record death save success ({{deathSaves.successes}} of 3)">
            {{#each deathSaves.successPips}}
            <span class="lpcs-ds-pip lpcs-ds-pip--success {{#if filled}}filled{{/if}}"
                  aria-hidden="true">
              <i class="fas fa-heart" aria-hidden="true"></i>
            </span>
            {{/each}}
          </div>

          {{!-- Failure group — tap target in physical mode, display-only in digital --}}
          <div class="lpcs-ds-group lpcs-ds-group--failure"
               data-action="incrementDeathSave" data-save-type="failure"
               role="button" tabindex="0"
               aria-label="Record death save failure ({{deathSaves.failures}} of 3)">
            {{#each deathSaves.failurePips}}
            <span class="lpcs-ds-pip lpcs-ds-pip--failure {{#if filled}}filled{{/if}}"
                  aria-hidden="true">
              <i class="fas fa-skull" aria-hidden="true"></i>
            </span>
            {{/each}}
          </div>

        </div>

        {{!-- Digital mode: central roll button. Hidden by CSS in physical mode. --}}
        <button class="lpcs-ds-roll-btn" data-action="rollDeathSave" type="button"
                aria-label="Roll death save">
          <i class="fas fa-dice-d20" aria-hidden="true"></i>
          Roll
        </button>

      </div>

    </div>{{!-- end .ds-view --}}

  </div>{{!-- end .lpcs-vitals-container --}}

  {{!-- HP management drawer — slides down from below the vitals container on tap --}}
  {{> lpcs-hp-drawer hp=hp}}

</div>

