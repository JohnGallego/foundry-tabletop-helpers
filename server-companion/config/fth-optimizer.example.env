# FTH Optimizer — Configuration
# Copy to /opt/fth-optimizer/.env and edit as needed

# Auth token (generated during install — keep secret)
FTH_AUTH_TOKEN=change-me

# Server
FTH_PORT=7890
FTH_HOST=0.0.0.0

# CORS — comma-separated list of allowed origins
# Set to your Foundry URL(s)
FTH_ALLOWED_ORIGINS=https://foundry.example.com

# Max upload size (bytes, default 100MB)
FTH_MAX_FILE_SIZE=104857600

# Temp directory for processing
FTH_TEMP_DIR=/tmp/fth-optimizer

# Log level: debug, info, warn, error
FTH_LOG_LEVEL=info

# FFmpeg paths (auto-detected if on PATH)
# FTH_FFMPEG_PATH=/usr/bin/ffmpeg
# FTH_FFPROBE_PATH=/usr/bin/ffprobe
